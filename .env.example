# ─────────────────────────────────────────────
# apps/api
# ─────────────────────────────────────────────
# NODE_ENV não fica aqui de propósito — Next.js e o próprio Node já o definem
# automaticamente por comando (dev/build/start); setá-lo aqui força o valor
# em todo processo carregado via dotenv-cli e quebra o build de produção do Next.
PORT=3000
LOG_LEVEL=info

# Origem(ns) liberada(s) para CORS, separadas por vírgula. "*" libera geral.
CORS_ORIGIN=*

# Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/confirma?schema=public"

# ─────────────────────────────────────────────
# apps/marketing
# ─────────────────────────────────────────────
# Base URL da API do Confirma, usada pela server action de waitlist para POST /waitlist.
NEXT_PUBLIC_API_URL=https://api.useconfirma.com.br

# ─────────────────────────────────────────────
# Compartilhado — Resend (e-mail transacional)
# ─────────────────────────────────────────────
RESEND_API_KEY=
MAIL_FROM="Confirma <no-reply@useconfirma.com.br>"
