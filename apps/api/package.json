{
    "name": "@confirma/api",
    "version": "1.0.0",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "tsx watch --env-file=.env src/server.ts",
        "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
        "start": "node --env-file=.env dist/server.js",
        "lint": "eslint .",
        "check-types": "tsc --noEmit",
        "db:generate": "node --env-file=.env ./node_modules/prisma/build/index.js generate",
        "db:migrate": "node --env-file=.env ./node_modules/prisma/build/index.js migrate dev",
        "db:reset": "node --env-file=.env ./node_modules/prisma/build/index.js migrate reset"
    },
    "dependencies": {
        "@confirma/contracts": "workspace:*",
        "@fastify/cors": "^10.0.1",
        "@fastify/rate-limit": "^10.1.1",
        "@fastify/swagger": "^9.4.0",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@scalar/fastify-api-reference": "^1.25.68",
        "fastify": "^5.1.0",
        "fastify-plugin": "^5.0.1",
        "fastify-type-provider-zod": "^4.0.2",
        "pg": "^8.13.1",
        "pino": "^9.5.0",
        "pino-pretty": "^13.0.0",
        "resend": "^4.0.1",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@confirma/config": "workspace:*",
        "@types/node": "^20",
        "@types/pg": "^8.11.10",
        "eslint": "^9.39.1",
        "prisma": "^7.8.0",
        "tsc-alias": "^1.8.10",
        "tsx": "^4.19.2",
        "typescript": "^5.9.2"
    }
}
